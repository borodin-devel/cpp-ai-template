{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "cmake: configure Debug",
      "type": "shell",
      "command": "cmake",
      "args": [
        "-S",
        ".",
        "-B",
        "build/Debug",
        "-DCMAKE_BUILD_TYPE=Debug",
        "-DCMAKE_EXPORT_COMPILE_COMMANDS=ON"
      ],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "cmake: configure Release",
      "type": "shell",
      "command": "cmake",
      "args": [
        "-S",
        ".",
        "-B",
        "build/Release",
        "-DCMAKE_BUILD_TYPE=Release",
        "-DCMAKE_EXPORT_COMPILE_COMMANDS=ON"
      ],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "cmake: configure RelWithDebInfo",
      "type": "shell",
      "command": "cmake",
      "args": [
        "-S",
        ".",
        "-B",
        "build/RelWithDebInfo",
        "-DCMAKE_BUILD_TYPE=RelWithDebInfo",
        "-DCMAKE_EXPORT_COMPILE_COMMANDS=ON"
      ],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "cmake: build Debug",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "build/Debug",
        "--parallel"
      ],
      "dependsOn": "cmake: configure Debug",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$gcc"
    },
    {
      "label": "cmake: build Release",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "build/Release",
        "--parallel"
      ],
      "dependsOn": "cmake: configure Release",
      "group": "build",
      "problemMatcher": "$gcc"
    },
    {
      "label": "cmake: build RelWithDebInfo",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "build/RelWithDebInfo",
        "--parallel"
      ],
      "dependsOn": "cmake: configure RelWithDebInfo",
      "group": "build",
      "problemMatcher": "$gcc"
    },
    {
      "label": "ctest: Debug",
      "type": "shell",
      "command": "ctest",
      "args": [
        "--test-dir",
        "build/Debug",
        "--output-on-failure"
      ],
      "dependsOn": "cmake: build Debug",
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "ctest: Release",
      "type": "shell",
      "command": "ctest",
      "args": [
        "--test-dir",
        "build/Release",
        "--output-on-failure"
      ],
      "dependsOn": "cmake: build Release",
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "format: clang-format",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "for dir in include src tests examples; do [ -d \"$dir\" ] && find \"$dir\" -type f \\( -name '*.c' -o -name '*.cc' -o -name '*.cpp' -o -name '*.cxx' -o -name '*.h' -o -name '*.hh' -o -name '*.hpp' -o -name '*.hxx' -o -name '*.ipp' -o -name '*.tpp' \\); done | xargs -r clang-format -i"
      ],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "clean: build",
      "type": "shell",
      "command": "cmake",
      "args": [
        "-E",
        "rm",
        "-rf",
        "build"
      ],
      "problemMatcher": []
    }
  ]
}
