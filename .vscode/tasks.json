{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "cmake: configure debug",
      "type": "shell",
      "command": "cmake",
      "args": ["--preset", "debug"],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "cmake: configure release",
      "type": "shell",
      "command": "cmake",
      "args": ["--preset", "release"],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "cmake: configure relwithdebinfo",
      "type": "shell",
      "command": "cmake",
      "args": ["--preset", "relwithdebinfo"],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "cmake: build debug",
      "type": "shell",
      "command": "cmake",
      "args": ["--build", "--preset", "debug"],
      "dependsOn": "cmake: configure debug",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$gcc"
    },
    {
      "label": "cmake: build release",
      "type": "shell",
      "command": "cmake",
      "args": ["--build", "--preset", "release"],
      "dependsOn": "cmake: configure release",
      "group": "build",
      "problemMatcher": "$gcc"
    },
    {
      "label": "cmake: build relwithdebinfo",
      "type": "shell",
      "command": "cmake",
      "args": ["--build", "--preset", "relwithdebinfo"],
      "dependsOn": "cmake: configure relwithdebinfo",
      "group": "build",
      "problemMatcher": "$gcc"
    },
    {
      "label": "ctest: debug",
      "type": "shell",
      "command": "ctest",
      "args": ["--preset", "debug"],
      "dependsOn": "cmake: build debug",
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "ctest: release",
      "type": "shell",
      "command": "ctest",
      "args": ["--preset", "release"],
      "dependsOn": "cmake: build release",
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "format: clang-format",
      "type": "shell",
      "command": ".agents/scripts/format.sh",
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "lint: clang-tidy",
      "type": "shell",
      "command": ".agents/scripts/lint.sh",
      "group": "build",
      "problemMatcher": "$gcc"
    },
    {
      "label": "clean: generated files",
      "type": "shell",
      "command": ".agents/scripts/clean.sh",
      "problemMatcher": []
    }
  ]
}
